{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lmfaole-party",
  "compatibility_date": "2026-04-20",
  "main": "./src/worker/index.ts",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    // Serves index.html for unknown paths so /cv resolves to cv.html via asset routing
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "lmfaole.party", "custom_domain": true },
    { "pattern": "www.lmfaole.party", "custom_domain": true },
    { "pattern": "budsjett.lmfaole.party", "custom_domain": true }
  ],
  "d1_databases": [
    {
      "binding": "BUDSJETT_DB",
      "database_name": "budsjett",
      "database_id": "25aed0d4-fd48-4014-8d7a-4d85294d6bcf",
      "migrations_dir": "migrations"
    }
  ]
}
