{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "outDir": "../../public",
    "rootDir": ".",
    "noEmit": false
  },
  "include": ["."],
  "exclude": ["**/*.test.ts"]
}
